# ──────────────────────────────────────────────────────────
# RunIT — .gitignore
# ──────────────────────────────────────────────────────────

# ── Rust / Cargo ──────────────────────────────────────────
/target/
**/*.rs.bk
Cargo.lock
!Cargo.lock

# ── macOS ─────────────────────────────────────────────────
.DS_Store
._*
.Spotlight-V100
.Trashes
*.swp
*~

# ── IDEs / Editors ────────────────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
.project
.classpath
.settings/

# ── Metal build artifacts ─────────────────────────────────
*.metallib
*.air
*.dia

# ── Models (large files — download separately) ────────────
*.gguf
*.bin
*.safetensors
*.pt
*.pth
*.onnx

# ── Tokenizers (download separately) ──────────────────────
# Keep tokenizer configs if checked in intentionally
# tokenizer.json

# ── Python (scripts/tools) ────────────────────────────────
__pycache__/
*.pyc
*.pyo
.venv/
venv/
.env

# ── Logs / Debug output ──────────────────────────────────
*.log
*.json.summary

# ── Archives ──────────────────────────────────────────────
*.zip
*.tar.gz
*.tgz

# ── Claude / AI assistant state ──────────────────────────
.claude/
